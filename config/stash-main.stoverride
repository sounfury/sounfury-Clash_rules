name: sounfury 主规则覆写
desc: 基于 config/main.ini 生成的 Stash 覆写，接管规则集、规则顺序、策略组和 DNS/hosts。

# Stash 覆写默认会把数组插入到原数组前面；这里需要模拟 subconverter 的 overwrite_original_rules=true，
# 因此对规则、策略组和规则集使用 #!replace，避免机场订阅原有规则继续参与匹配。

dns:
  enable: true
  ipv6: true
  use-hosts: true
  prefer-h3: true
  listen: 0.0.0.0:53
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter: #!replace
    - "*"
    - +.lan
    - +.local
    - time.*.com
    - ntp.*.com
    - +.market.xiaomi.com
  default-nameserver: #!replace
    - https://223.5.5.5/dns-query
  nameserver: #!replace
    - https://dns.alidns.com/dns-query
  proxy-server-nameserver: #!replace
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query
  fallback: #!replace
    - https://dns.cloudflare.com/dns-query
  fallback-filter: #!replace
    geoip: true
    geoip-code: CN
    geosite:
      - gfw
    ipcidr:
      - 240.0.0.0/4
  nameserver-policy: #!replace
    geosite:cn,private,apple: https://dns.alidns.com/dns-query
    geosite:!cn,gfw: https://posvdm.cloudflare-gateway.com/dns-query

hosts: #!replace
  iosapps.itunes.apple.com: hls.itunes.apple.com.mwcname.com

proxy-groups: #!replace
  - name: 👋 手动切换
    type: select
    proxies:
      - ⚡ 自动选择
      - 🇭🇰 香港节点
      - 🇺🇲 美国节点
      - 🇸🇬 狮城节点
      - 🇯🇵 日本节点
      - 🇹🇼 台湾节点
      - 🇪🇺 欧洲节点
      - 🇹🇷 土耳其节点
      - 🐔 小鸡节点
      - 🏷️ 低倍率
      - 🧊 冷门节点
      - DIRECT

  - name: 🚀 国外网站
    type: select
    proxies:
      - ⚡ 自动选择
      - 👋 手动切换

  - name: 📨 Telegram
    type: select
    proxies:
      - ⚡ 自动选择
      - 🏷️ 低倍率
      - 🇭🇰 香港节点
      - 🇺🇲 美国节点
      - 🇸🇬 狮城节点
      - 🇯🇵 日本节点
      - 🇹🇼 台湾节点
      - 🧊 冷门节点
      - 👋 手动切换

  - name: 🤖 AI
    type: select
    proxies:
      - 🇸🇬 狮城节点
      - 🐔 小鸡节点
      - 🏷️ 低倍率
      - 🇭🇰 香港节点
      - 🇺🇲 美国节点
      - 🇯🇵 日本节点
      - 🇹🇼 台湾节点
      - 🧊 冷门节点
      - 👋 手动切换

  - name: 🎮 游戏服务
    type: select
    proxies:
      - 🇸🇬 狮城节点
      - 🐔 小鸡节点
      - 🏷️ 低倍率
      - 🇭🇰 香港节点
      - 🇺🇲 美国节点
      - 🇯🇵 日本节点
      - 🇹🇼 台湾节点
      - 🧊 冷门节点
      - 👋 手动切换
      - DIRECT

  - name: 📺 Emby
    type: select
    proxies:
      - 🏷️ 低倍率
      - 🇭🇰 香港节点
      - 🇺🇲 美国节点
      - 🇸🇬 狮城节点
      - 🇯🇵 日本节点
      - 🇹🇼 台湾节点
      - 🧊 冷门节点
      - 👋 手动切换
      - DIRECT

  - name: 🎶 Spotify
    type: select
    proxies:
      - 🇹🇷 土耳其节点
      - 🏷️ 低倍率
      - 🇺🇲 美国节点
      - 🇭🇰 香港节点
      - 🇸🇬 狮城节点
      - 🇯🇵 日本节点
      - 🇹🇼 台湾节点
      - 🧊 冷门节点
      - 👋 手动切换
      - DIRECT

  - name: 📚 E站
    type: select
    proxies:
      - 🇪🇺 欧洲节点
      - 🇺🇲 美国节点
      - 👋 手动切换

  - name: 🥵 不许涩涩
    type: select
    proxies:
      - 🇸🇬 狮城节点
      - 🏷️ 低倍率
      - 🇭🇰 香港节点
      - 🇺🇲 美国节点
      - 🇯🇵 日本节点
      - 🇹🇼 台湾节点
      - 🧊 冷门节点
      - 👋 手动切换
      - DIRECT

  - name: 🐟 漏网之鱼
    type: select
    proxies:
      - 🇸🇬 狮城节点
      - 🏷️ 低倍率
      - 🇭🇰 香港节点
      - 🇺🇲 美国节点
      - 🇯🇵 日本节点
      - 🇹🇼 台湾节点
      - 🧊 冷门节点
      - 👋 手动切换
      - DIRECT

  - name: 📦 大宗流量
    type: select
    proxies:
      - 🏷️ 低倍率
      - 🇸🇬 狮城节点
      - 🇭🇰 香港节点
      - 🇺🇲 美国节点
      - 🇯🇵 日本节点
      - 🇹🇼 台湾节点
      - 🧊 冷门节点
      - 👋 手动切换
      - DIRECT

  - name: 💻 环境仓库
    type: select
    proxies:
      - 🏷️ 低倍率
      - 🐔 小鸡节点
      - 🇸🇬 狮城节点
      - 🇭🇰 香港节点
      - 🇺🇲 美国节点
      - 🇯🇵 日本节点
      - 🇹🇼 台湾节点
      - 🧊 冷门节点
      - 👋 手动切换
      - DIRECT

  - name: ⚡ 自动选择
    type: url-test
    include-all: true
    filter: '(?i)^(?=.*(🇭🇰|香港|HK|Hong\s*Kong|🇺🇲|🇺🇸|美国|US|United.?States|洛杉矶|圣何塞|🇸🇬|新加坡|狮城|SG|Singapore|🇯🇵|日本|东京|JP|Japan|🇹🇼|台湾|TW|Tai|Taiwan))(?!.*(实验|低倍率|小鸡|chicken|vps|剩余|Expire|Traffic|GB|官网|网址|官址|套餐|应急|失联|重置|到期|过期|订阅)).*'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 5

  - name: 🏷️ 低倍率
    type: url-test
    include-all: true
    # 低倍率节点命名不统一，兼容“实验/低倍/0.x/折扣”等常见写法。
    filter: '(?i)(实验|低倍率|低倍|0\.[1-9]\s*(?:x|倍)?|[1-5]折)'
    url: https://www.gstatic.com/generate_204
    interval: 300
    tolerance: 5

  - name: 🐔 小鸡节点
    type: url-test
    include-all: true
    filter: '(?i)chicken|vps|server|小鸡|鸡'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 5

  - name: 🇭🇰 香港节点
    type: url-test
    include-all: true
    filter: '(?i)🇭🇰|香港|HK|Hong\s*Kong'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 5

  - name: 🇺🇲 美国节点
    type: url-test
    include-all: true
    filter: '(?i)🇺🇲|🇺🇸|美国|US|United.?States|洛杉矶|圣何塞'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 5

  - name: 🇸🇬 狮城节点
    type: url-test
    include-all: true
    filter: '(?i)🇸🇬|新加坡|狮城|SG|Singapore'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 5

  - name: 🇪🇺 欧洲节点
    type: url-test
    include-all: true
    filter: '(?i)🇪🇺|欧洲|Europe|🇩🇪|德国|Germany|Frankfurt|法兰克福|Berlin|柏林|🇳🇱|荷兰|Netherlands|Amsterdam|阿姆斯特丹|🇬🇧|英国|United.?Kingdom|London|伦敦|🇫🇷|法国|France|Paris|巴黎|🇮🇪|爱尔兰|Ireland|Dublin|都柏林'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 5

  - name: 🇹🇷 土耳其节点
    type: url-test
    include-all: true
    filter: '(?i)🇹🇷|土耳其|TR|Turkey|Turkiye|Türkiye|Istanbul'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 5

  - name: 🇯🇵 日本节点
    type: url-test
    include-all: true
    filter: '(?i)🇯🇵|日本|东京|JP|Japan'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 5

  - name: 🇹🇼 台湾节点
    type: url-test
    include-all: true
    filter: '(?i)🇹🇼|台湾|TW|Taiwan|Tai'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 5

  - name: 🧊 冷门节点
    type: select
    include-all: true
    # 负向筛选常见地区和订阅信息节点，保留主流地区以外的可选出口。
    filter: '^(?!.*(🇭🇰|香港|HK|Hong|🇺🇸|🇺🇲|美国|洛杉矶|圣何塞|US|United.?States|🇸🇬|新加坡|狮|SG|Singapore|🇯🇵|日本|东京|JP|Japan|🇹🇼|台湾|TW|Tai|Taiwan|剩余|Expire|Traffic|GB)).*'

  - name: 🛑 广告隐私
    type: select
    proxies:
      - REJECT
      - DIRECT

  - name: 🎯 全球直连
    type: select
    proxies:
      - DIRECT

