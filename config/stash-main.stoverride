rules: #!replace
  - RULE-SET,ad_anti_ad,🛑 广告隐私
  - RULE-SET,ad_adblock_lite,🛑 广告隐私
  - RULE-SET,ad_reject_posvdm,🛑 广告隐私

  - RULE-SET,direct_sounfury,🎯 全球直连
  - RULE-SET,direct_china_domain,🎯 全球直连
  - RULE-SET,direct_china_company_ip,🎯 全球直连
  - RULE-SET,direct_download,🎯 全球直连
  - RULE-SET,direct_apple_cdn,🎯 全球直连
  - RULE-SET,direct_apple_cn,🎯 全球直连
  - RULE-SET,direct_apple_services,🎯 全球直连
  - RULE-SET,direct_unban,🎯 全球直连
  - RULE-SET,direct_microsoft,🎯 全球直连

  - RULE-SET,ai_sounfury,🤖 AI
  - RULE-SET,ai_sukka,🤖 AI
  - RULE-SET,low_sounfury,📦 大宗流量
  - RULE-SET,env_repo_sounfury,💻 环境仓库

  - RULE-SET,game_platform,🎮 游戏服务
  - RULE-SET,emby_sounfury,📺 Emby
  - RULE-SET,spotify_sounfury,🎶 Spotify
  - RULE-SET,ehentai_sounfury,📚 E站
  - RULE-SET,sexy_sounfury,🥵 不许涩涩

  - RULE-SET,telegram_non_ip,📨 Telegram
  - RULE-SET,telegram_ip,📨 Telegram
  - RULE-SET,google_fcm,🚀 国外网站
  - RULE-SET,netflix_acl4ssr,🚀 国外网站
  - RULE-SET,netflix_lm_firefly,🚀 国外网站
  - RULE-SET,disney_plus,🚀 国外网站
  - RULE-SET,bahamut,🚀 国外网站
  - RULE-SET,proxy_sounfury,🚀 国外网站
  - RULE-SET,proxy_lite,🚀 国外网站

  - GEOSITE,cn,🎯 全球直连
  - GEOIP,CN,🎯 全球直连,no-resolve
  - FINAL,🐟 漏网之鱼
